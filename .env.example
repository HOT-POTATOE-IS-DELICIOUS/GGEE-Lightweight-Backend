# ── Server ───────────────────────────────────────────────
SERVER_PORT=8080
NODE_ENV=development

# ── Database (PostgreSQL) — HOST-side ────────────────────
# Used when you run the app or its tooling directly on the host
# (npm run start:dev, npm run migration:run, npm run test:e2e).
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=root
DATABASE_PASSWORD=password
DATABASE_NAME=ggee
# Published port + settings for the bundled `postgres` compose service.
POSTGRES_DB=ggee
POSTGRES_PORT=5432
TZ=Asia/Seoul

# ── Redis (crawler dedup) — HOST-side ────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Datastores as seen by the BACKEND CONTAINER ──────────
# Leave blank to use the bundled `postgres` / `redis` compose services.
# Set to an external host or IP (e.g. a managed DB) to point the backend elsewhere;
# then start the backend without the bundled ones:
#   docker compose up -d --no-deps backend
BACKEND_DATABASE_HOST=
BACKEND_DATABASE_PORT=
BACKEND_REDIS_HOST=
BACKEND_REDIS_PORT=

# ── CORS ─────────────────────────────────────────────────
CORS_PATH_PATTERN=/**
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_TOKEN_ACTIVE_TIME=3600000
JWT_REFRESH_TOKEN_ACTIVE_TIME=1209600000
JWT_HEADER=Authorization
JWT_PREFIX=Bearer
# Base64-encoded HMAC secret (decoded before use). Generate: openssl rand -base64 48
JWT_SECRET_KEY=

# ── Snowflake ────────────────────────────────────────────
SNOWFLAKE_WORKER_ID=1

# ── External AI services ─────────────────────────────────
# Injected into the backend container verbatim, so use an address reachable from INSIDE it:
#   external server   -> http://10.0.0.7:9001  |  https://audit.internal.example.com
#   service on host   -> http://host.docker.internal:9001
#   another container -> http://<service-name>:9001
GGEE_AI_AUDIT_BASE_URL=http://localhost:9001
GGEE_AI_AUDIT_TIMEOUT=10s
GGEE_AI_ISSUE_BASE_URL=http://localhost:9002
GGEE_AI_ISSUE_TIMEOUT=10s
GGEE_AI_REACTION_BASE_URL=http://localhost:9003
GGEE_AI_REACTION_TIMEOUT=10s
GGEE_AI_STRATEGY_BASE_URL=http://localhost:9004
GGEE_AI_STRATEGY_TIMEOUT=30s

# ── Crawler (replaces Kafka) ─────────────────────────────
# Backend -> crawler: index request (replaces `crawl.request` topic)
CRAWLER_BASE_URL=http://localhost:9005
# Redis dedup sliding TTL. Bare number = seconds; units also work ("1h", "30m").
GGEE_CRAWLER_DEDUP_TTL=1h
# Backend -> downstream: forward deduped posts/comments (optional; blank = log only)
CRAWLER_DEDUP_FORWARD_URL=
