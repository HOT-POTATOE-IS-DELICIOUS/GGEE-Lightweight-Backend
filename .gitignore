node_modules/
dist/

# Never commit real environment files; .env.example is the tracked template.
.env
.env.*
!.env.example

*.log
coverage/
.DS_Store
*.tsbuildinfo

# Editor state (workspace.xml churns on every window move).
.idea/
.vscode/

# oh-my-claudecode runtime state: session UUIDs, HUD caches, agent replays.
# `.omc/skills/` is the exception — project-scoped skills are meant to be shared.
.omc/*
!.omc/skills/
